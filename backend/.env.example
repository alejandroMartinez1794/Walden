# Example environment variables for the backend
# Copy this file to `.env` inside the `backend/` folder and fill the values.

# MongoDB connection string (replace with your cluster/DB)
MONGO_URL=mongodb://localhost:27017/psiconepsis

# JWT secret used to sign tokens (use a long random string in production)
JWT_SECRET_KEY=your_jwt_secret_here

# Google OAuth2 credentials (create these in Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/calendar/google-callback

# Backend port (default 8000)
PORT=8000
# Public backend URL (for verification links)
BACKEND_URL=http://localhost:8000

# Allowed CORS origins (comma-separated)
# Example: http://localhost:5173,https://psiconepsis.com
CORS_ORIGINS=http://localhost:5173

# Frontend URL (for links in automated emails)
# Development:
FRONTEND_URL=http://localhost:5173
# Production:
# FRONTEND_URL=https://psiconepsis.com

# Automation Settings
# Set to false to disable all automation jobs
AUTOMATION_ENABLED=true
# Timezone used by cron jobs
AUTOMATION_TIMEZONE=America/Bogota
# Max items processed per run
AUTOMATION_MAX_BATCH=50
# Throttle between emails (ms)
AUTOMATION_EMAIL_THROTTLE_MS=1000
# Renotify critical alerts after X hours
AUTOMATION_ALERT_RENOTIFY_HOURS=2

# Auth security
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
EMAIL_VERIFICATION_TTL_MINUTES=60

# hCaptcha (anti-bots)
HCAPTCHA_SECRET=your_hcaptcha_secret
HCAPTCHA_VERIFY_URL=https://hcaptcha.com/siteverify

# ============= PHASE 4: MONITORING & OBSERVABILITY =============

# New Relic APM (Application Performance Monitoring)
# Student Pack: FREE while student ($300/month value)
# Get key from: https://newrelic.com/students → Connect GitHub → Get license key
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key_here
NEW_RELIC_APP_NAME=Psiconepsis API
# Note: New Relic auto-detects NODE_ENV, no need to set it

# Sentry Error Tracking
# Student Pack: FREE 50,000 errors/month while student ($26/month value)
# Get DSN from: https://sentry.io/signup/ → Connect GitHub → Create project → Copy DSN
SENTRY_DSN=https://your_key@o123456.ingest.sentry.io/123456
# Note: Sentry auto-detects NODE_ENV and version from package.json

# Brevo Email Service (formerly Sendinblue)
# FREE PERMANENT: 300 emails/day (no student pack needed)
# Get API key from: https://app.brevo.com → Settings → SMTP & API → Create API Key
BREVO_API_KEY=xkeysib-your_api_key_here
# Verified sender email (must be verified in Brevo dashboard)
EMAIL_FROM=noreply@psiconepsis.app
# Optional BCC for admin notifications
EMAIL_BCC=admin@psiconepsis.app

# ============= END PHASE 4 =============

# ============= PHASE 5: PERFORMANCE & SCALABILITY =============

# Redis Cache (Optional - improves performance)
# Railway: Add Redis plugin and copy REDIS_URL
# Local: docker run -d -p 6379:6379 --name redis redis:alpine
REDIS_URL=redis://localhost:6379
# Railway format: redis://default:password@host:port

# Database connection pool (already configured in code)
# Current settings: maxPoolSize=20, minPoolSize=5 (optimized for Railway free tier)

# ============= END PHASE 5 =============

# Email Configuration (Nodemailer) - DEPRECATED: Replace with Brevo
# Option A: Using a Service (Recommended for Gmail/Outlook)
# For Gmail: EMAIL_SERVICE=gmail
# For Outlook/Hotmail: EMAIL_SERVICE=hotmail
# EMAIL_SERVICE=gmail

# Option B: Custom SMTP (If EMAIL_SERVICE is not set)
# Gmail: smtp.gmail.com (Port 587)
# Outlook: smtp.office365.com (Port 587)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587

# Credentials
# For Gmail: Use your email and an "App Password" (if 2FA is on).
# For Outlook: Use your email and password (or App Password).
# EMAIL_USERNAME=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password

# Notes:
# - Do NOT commit your real `.env` file with secrets to source control.
# - After creating `.env`, restart the backend server (npm run start-dev).
# - Old EMAIL_SERVICE/EMAIL_HOST/EMAIL_PORT config is DEPRECATED, use BREVO_API_KEY instead