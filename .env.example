# Variables de entorno para desarrollo local con Docker
# COPIAR ESTE ARCHIVO A .env Y ACTUALIZAR LOS VALORES

# Node Environment
NODE_ENV=production

# Server
PORT=8000

# MongoDB (usar MongoDB Atlas en producción)
MONGO_URL=mongodb://admin:adminpassword@mongo:27017/psiconepsis?authSource=admin
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=adminpassword

# Redis
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=redispassword

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key-here!!

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/calendar/google-callback

# Email (Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000

# 2FA
TWO_FACTOR_ENABLED=true
TWO_FACTOR_APP_NAME=Psiconepsis

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Colombia Compliance
COMPANY_NAME=Psiconepsis
COMPANY_NIT=pending
COMPANY_ADDRESS=Bogotá, Colombia
