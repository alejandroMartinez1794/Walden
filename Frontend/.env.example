# Frontend environment variables example
# Copy this file to `.env` in the Frontend/ folder and edit values for your environment.

# Backend API base URL used by the frontend (used in src/config.js as VITE_BACKEND_URL)
# Keep the /api/v1 suffix so the frontend can call endpoints like ${BASE_URL}/auth/login
VITE_BACKEND_URL=http://localhost:5000/api/v1

# Example: if you host your backend on a different port or domain, change accordingly
# VITE_BACKEND_URL=https://api.my-domain.com/api/v1

# After editing .env, restart the Vite dev server (npm run dev) to pick up changes.

# hCaptcha site key (anti-bots)
VITE_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key
